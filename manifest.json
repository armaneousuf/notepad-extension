{
  "manifest_version": 3,
  "name": "Notepad",
  "version": "1.0.0",
  "description": "A focused, persistent notepad that lives in your browser.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Notepad",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "activeTab", "scripting", "unlimitedStorage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
